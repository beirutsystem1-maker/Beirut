# Variables de entorno del servidor local Beirut
# Copia este archivo como .env y rellena los valores

# ── Supabase (nube) ──────────────────────────────────────────────────────────
# Obténlos desde: https://supabase.com/dashboard → tu proyecto → Settings → API
SUPABASE_URL=https://lqvlwzsmvchpgmdxeugj.supabase.co
SUPABASE_SERVICE_KEY=PEGA_AQUI_TU_SERVICE_ROLE_KEY

# ── Base de Datos VALERY (Firebird) ──────────────────────────────────────────
# Estas credenciales suelen ser SYSDBA / masterkey
VALERY_DB_HOST=127.0.0.1
VALERY_DB_PORT=3050
VALERY_DB_PATH=C:\Valery\Datos\valery.fdb
VALERY_DB_USER=SYSDBA
VALERY_DB_PASSWORD=masterkey
